generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(uuid())
  email                String               @unique
  name                 String
  role                 Role                 @default(account)
  division             String?
  isActive             Boolean              @default(true) @map("is_active")
  isVp                 Boolean              @default(false) @map("is_vp")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  clientsManaged           Client[]
  clientFieldChanges       ClientFieldHistory[] @relation("ClientFieldChanger")
  fieldChangesActioned     LeadFieldHistory[]
  stageChangesActioned     LeadStageHistory[]
  leadsAssigned            Lead[]
  documentsUploaded        PipelineDocument[]
  targets                  Target[]
  activitiesAssigned       Activity[]          @relation("ActivityAssignee")
  activitiesCreated        Activity[]          @relation("ActivityCreator")
  comments                 Comment[]           @relation("CommentAuthor")
  followings               Follower[]          @relation("FollowerUser")
  notifications            Notification[]
  assignedAlerts           Alert[]             @relation("AlertAssignee")

  @@map("users")
}

model Client {
  id                  String               @id @default(uuid())
  name                String
  industry            String?
  engagementType      EngagementType       @map("engagement_type")
  contractStart       DateTime?            @map("contract_start") @db.Date
  contractEnd         DateTime?            @map("contract_end") @db.Date
  monthlyValue        Decimal?             @map("monthly_value") @db.Decimal(15, 2)
  annualValue         Decimal?             @map("annual_value") @db.Decimal(15, 2)
  healthStatus        HealthStatus         @default(healthy) @map("health_status")
  primaryAe           String?              @map("primary_ae")
  notes               String?
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  customerCode        String?              @unique @map("customer_code")
  orgSize             String?              @map("org_size")
  clientStatus        ClientStatus?        @map("client_status")
  deletedAt           DateTime?            @map("deleted_at")
  ae                  User?                @relation(fields: [primaryAe], references: [id])
  contacts            Contact[]
  fieldHistory        ClientFieldHistory[]
  leads               Lead[]
  upsellOpportunities UpsellOpportunity[]
  activities          Activity[]
  comments            Comment[]
  followers           Follower[]
  alerts              Alert[]
  healthSnapshots     ClientHealthSnapshot[]

  @@map("clients")
}

model ClientFieldHistory {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  field     String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedBy String   @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  changer   User     @relation("ClientFieldChanger", fields: [changedBy], references: [id])

  @@map("client_field_history")
}

model Contact {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  name      String
  role      String?
  email     String?
  phone     String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model UpsellOpportunity {
  id             String       @id @default(uuid())
  clientId       String       @map("client_id")
  service        String
  status         UpsellStatus @default(identified)
  estimatedValue Decimal?     @map("estimated_value") @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("upsell_opportunities")
}

model Lead {
  id                   String             @id @default(uuid())
  stage                PipelineStage      @default(leads)
  projectType          ProjectType        @map("project_type")
  billingPlan          String?            @map("billing_plan")
  notes                String?
  createdAt            DateTime           @default(now()) @map("created_at")
  closedAt             DateTime?          @map("closed_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  actualRevenue        Decimal?           @map("actual_revenue") @db.Decimal(15, 2)
  clientId             String             @map("client_id")
  description          String?
  invoiceRequestedAt   DateTime?          @map("invoice_requested_at")
  lossDealReason       String?            @map("loss_deal_reason")
  productLine          ProductLine        @map("product_line")
  projectedRevenue     Decimal?           @map("projected_revenue") @db.Decimal(15, 2)
  salesId              String?            @map("sales_id")
  quarter              String?
  expectedCloseDate    DateTime?          @map("expected_close_date")
  probability          Decimal?           @db.Decimal(5, 2)
  probabilityIsManual  Boolean            @default(false) @map("probability_is_manual")
  lostReason           LostReason?        @map("lost_reason")
  nextActivityAt       DateTime?          @map("next_activity_at")
  deletedAt            DateTime?          @map("deleted_at")
  renewedFromLeadId    String?            @map("renewed_from_lead_id")
  fieldHistory         LeadFieldHistory[]
  stageHistory         LeadStageHistory[]
  activities           Activity[]
  comments             Comment[]
  followers            Follower[]
  client               Client             @relation(fields: [clientId], references: [id])
  sales                User?              @relation(fields: [salesId], references: [id])
  documents            PipelineDocument[]
  alerts               Alert[]
  renewedFromLead      Lead?              @relation("LeadRenewal", fields: [renewedFromLeadId], references: [id])
  renewals             Lead[]             @relation("LeadRenewal")

  @@map("leads")
}

model LeadStageHistory {
  id        String        @id @default(uuid())
  leadId    String        @map("lead_id")
  fromStage PipelineStage @map("from_stage")
  toStage   PipelineStage @map("to_stage")
  changedBy String        @map("changed_by")
  changedAt DateTime      @default(now()) @map("changed_at")
  changer   User          @relation(fields: [changedBy], references: [id])
  lead      Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_stage_history")
}

model LeadFieldHistory {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  field     String
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  changedBy String   @map("changed_by")
  changedAt DateTime @default(now()) @map("changed_at")
  changer   User     @relation(fields: [changedBy], references: [id])
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_field_history")
}

model PipelineDocument {
  id         String       @id @default(uuid())
  leadId     String       @map("lead_id")
  type       DocumentType
  fileUrl    String       @map("file_url")
  uploadedAt DateTime     @default(now()) @map("uploaded_at")
  uploadedBy String       @map("uploaded_by")
  createdAt  DateTime     @default(now()) @map("created_at")
  fileName   String?      @map("file_name")
  lead       Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  uploader   User         @relation(fields: [uploadedBy], references: [id])

  @@map("pipeline_documents")
}

model Target {
  id              String     @id @default(uuid())
  periodMonth     Int        @map("period_month")
  periodYear      Int        @map("period_year")
  revenueTarget   Decimal    @map("revenue_target") @db.Decimal(15, 2)
  newClientTarget Int        @default(0) @map("new_client_target")
  type            TargetType @default(monthly)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  salesId         String?    @map("sales_id")
  sales           User?      @relation(fields: [salesId], references: [id])

  @@unique([periodMonth, periodYear, type, salesId])
  @@map("targets")
}

enum Role {
  admin
  commercial_director
  account_manager
  account
  operation
  hr
  finance
}

enum EngagementType {
  retainer
  project
  both
}

enum HealthStatus {
  healthy
  at_risk
  churned
}

enum ClientStatus {
  active
  inactive
  lead
}

enum UpsellStatus {
  identified
  pitched
  won
  lost
}

enum PipelineStage {
  leads
  pipeline
  negotiation
  closed_won
  lost_deal
  invoiced
  contract_renewal
  no_response
}

enum ProjectType {
  one_time
  retainer
}

enum ProductLine {
  stracomm
  smm
  creative_strategy
  media_buying
  ads_management
  production
  others
}

enum DocumentType {
  quotation
  quotation_signed
  contract
  other
}

enum TargetType {
  monthly
  quarterly
}

enum LostReason {
  budget
  competitor
  timing
  no_decision
  requirements_mismatch
  other
}

enum ActivityType {
  call
  email
  meeting
  todo
  deadline
}

enum ActivityStatus {
  open
  done
  canceled
}

model Activity {
  id         String         @id @default(uuid())
  type       ActivityType
  subject    String
  note       String?
  dueDate    DateTime       @map("due_date") @db.Date
  status     ActivityStatus @default(open)
  doneAt     DateTime?      @map("done_at")
  leadId     String?        @map("lead_id")
  clientId   String?        @map("client_id")
  assignedTo String         @map("assigned_to")
  createdBy  String         @map("created_by")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  lead       Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client     Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee   User           @relation("ActivityAssignee", fields: [assignedTo], references: [id])
  creator    User           @relation("ActivityCreator", fields: [createdBy], references: [id])

  @@index([assignedTo, status, dueDate])
  @@index([leadId, status])
  @@index([clientId, status])
  @@map("activities")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

model Comment {
  id        String    @id @default(uuid())
  body      String
  mentions  String[]  @default([])
  leadId    String?   @map("lead_id")
  clientId  String?   @map("client_id")
  authorId  String    @map("author_id")
  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  author    User      @relation("CommentAuthor", fields: [authorId], references: [id])
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([clientId, createdAt])
  @@map("comments")
}

model Follower {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  leadId   String?  @map("lead_id")
  clientId String?  @map("client_id")
  createdAt DateTime @default(now()) @map("created_at")
  user     User     @relation("FollowerUser", fields: [userId], references: [id])
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client   Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, leadId])
  @@unique([userId, clientId])
  @@map("followers")
}

enum AlertType {
  renewal_t60
  renewal_t30
  health_drop
  stale_deal
}

enum AlertStatus {
  open
  acknowledged
  resolved
}

enum NotificationType {
  mention
  lead_assigned
  activity_due
  activity_overdue
  alert
  stage_change
}

model Alert {
  id          String      @id @default(uuid())
  type        AlertType
  clientId    String?     @map("client_id")
  leadId      String?     @map("lead_id")
  assignedTo  String?     @map("assigned_to")
  status      AlertStatus @default(open)
  triggeredAt DateTime    @default(now()) @map("triggered_at")
  resolvedAt  DateTime?   @map("resolved_at")
  dedupeKey   String      @unique @map("dedupe_key")
  client      Client?     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead        Lead?       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignee    User?       @relation("AlertAssignee", fields: [assignedTo], references: [id])

  @@index([clientId, status])
  @@index([status, triggeredAt])
  @@map("alerts")
}

model ClientHealthSnapshot {
  id                String       @id @default(uuid())
  clientId          String       @map("client_id")
  score             Int
  band              HealthStatus
  signalActivity    Int          @map("signal_activity")
  signalRenewal     Int          @map("signal_renewal")
  signalRevenue     Int          @map("signal_revenue")
  signalEngagement  Int          @map("signal_engagement")
  computedAt        DateTime     @default(now()) @map("computed_at")
  client            Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, computedAt])
  @@map("client_health_snapshots")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String           @map("user_id")
  type       NotificationType
  title      String
  body       String?
  entityType String?          @map("entity_type")
  entityId   String?          @map("entity_id")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@map("notifications")
}
